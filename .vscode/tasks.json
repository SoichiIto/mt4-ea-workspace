{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile Current File",
            "type": "shell",
            "command": "powershell.exe",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\tools\\compile_current.ps1",
                "${file}",
                "${workspaceFolder}\\compile.log"
            ],
            "problemMatcher": []
        },
        {
            "label": "Deploy Current EA",
            "type": "shell",
            "command": "${workspaceFolder}\\tools\\copy_current_ea.bat",
            "args": [
                "${file}"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Compile Current File"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}